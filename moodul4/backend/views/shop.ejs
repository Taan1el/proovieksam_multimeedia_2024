<%- include('partials/header', { title: 'NEXUS - Store', user }) %>

<section class="page-intro">
  <span class="eyebrow">Store</span>
  <h1>Official NEXUS merch</h1>
  <p>Official team store with fast filters, price control and quick access to every drop.</p>
</section>

<section class="filter-card">
  <form method="GET" action="/shop" class="filter-grid">
    <div class="field">
      <label for="category">Category</label>
      <% const currentCategory = String(query?.category || 'all'); %>
      <select id="category" name="category">
        <option value="all" <%= currentCategory === 'all' ? 'selected' : '' %>>All</option>
        <option value="tshirt" <%= currentCategory === 'tshirt' ? 'selected' : '' %>>Shirts</option>
        <option value="mouse" <%= currentCategory === 'mouse' ? 'selected' : '' %>>Mouse</option>
        <option value="hat" <%= currentCategory === 'hat' ? 'selected' : '' %>>Cap</option>
        <option value="mug" <%= currentCategory === 'mug' ? 'selected' : '' %>>Mug</option>
      </select>
    </div>

    <div class="field">
      <label for="sort">Sort</label>
      <% const currentSort = String(query?.sort || 'name'); %>
      <select id="sort" name="sort">
        <option value="name" <%= currentSort === 'name' ? 'selected' : '' %>>Name</option>
        <option value="price-asc" <%= currentSort === 'price-asc' ? 'selected' : '' %>>Price low-high</option>
        <option value="price-desc" <%= currentSort === 'price-desc' ? 'selected' : '' %>>Price high-low</option>
      </select>
    </div>

    <div class="field">
      <label for="maxPrice">Max price</label>
      <input id="maxPrice" name="maxPrice" type="number" min="1" step="1" value="<%= query?.maxPrice || 9999 %>">
    </div>

    <div class="filter-actions">
      <button class="button primary" type="submit">Apply</button>
      <a class="button ghost" href="/shop">Reset</a>
    </div>
  </form>
</section>

<section class="product-grid">
  <% products.forEach((product) => { %>
    <a class="product-card" href="/product/<%= product.id %>">
      <div class="product-thumb">
        <% if (product.thumb) { %>
          <img src="<%= product.thumb %>" alt="<%= product.name %>">
        <% } %>
      </div>
      <div class="product-body">
        <strong><%= product.name %></strong>
        <span><%= product.description %></span>
        <div class="product-meta">
          <small><%= product.category %></small>
          <b>EUR <%= product.price %></b>
        </div>
      </div>
    </a>
  <% }) %>
</section>

<%- include('partials/footer') %>
