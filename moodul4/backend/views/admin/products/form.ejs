<%- include('../../partials/header', { title: product?.id ? 'Muuda toodet' : 'Lisa toode', user }) %>

<section style="padding:16px 0">
  <div class="card" style="padding:14px;max-width:900px;margin:0 auto">
    <h2><%= product?.id ? 'Muuda toodet' : 'Lisa toode' %></h2>

    <form method="POST" enctype="multipart/form-data" action="<%= product?.id ? ('/admin/products/' + product.id) : '/admin/products' %>">
      <div class="grid cols-2">
        <div class="field">
          <label>Nimi</label>
          <input name="name" value="<%= product?.name || '' %>" />
          <% if (errors?.name) { %><div class="error"><%= errors.name %></div><% } %>
        </div>
        <div class="field">
          <label>Kategooria</label>
          <input name="category" value="<%= product?.category || '' %>" placeholder="tshirt / hat / mouse / mug" />
          <% if (errors?.category) { %><div class="error"><%= errors.category %></div><% } %>
        </div>
      </div>

      <div class="field">
        <label>Kirjeldus</label>
        <textarea name="description" rows="4"><%= product?.description || '' %></textarea>
        <% if (errors?.description) { %><div class="error"><%= errors.description %></div><% } %>
      </div>

      <div class="grid cols-2">
        <div class="field">
          <label>Hind (€)</label>
          <input name="price" type="number" step="0.01" value="<%= product?.price || '' %>" />
          <% if (errors?.price) { %><div class="error"><%= errors.price %></div><% } %>
        </div>
        <div class="field">
          <label>Pildid</label>
          <input name="images" type="file" multiple accept="image/*" />
          <div class="muted">Valikuline: kuni 6 faili.</div>
        </div>
      </div>

      <div class="grid cols-2">
        <div class="field">
          <label>Suurused (komadega)</label>
          <input name="sizes" value="<%= product?.sizes || '' %>" placeholder="S,M,L,XL" />
        </div>
        <div class="field">
          <label>Värvid (komadega)</label>
          <input name="colors" value="<%= product?.colors || '' %>" placeholder="Must, Roheline, Valge" />
        </div>
      </div>

      <% if (images?.length) { %>
        <div class="field">
          <label>Olemasolevad pildid</label>
          <div class="grid cols-3">
            <% images.forEach(i => { %>
              <div class="thumb"><img src="<%= i.path %>" alt="" style="width:100%;height:100%;object-fit:cover" /></div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn primary" type="submit">Salvesta</button>
        <a class="btn" href="/admin/products">Tagasi</a>
      </div>
    </form>
  </div>
</section>

<%- include('../../partials/footer') %>
