<%- include('../partials/header', { title: 'NEXUS - Contact inbox', user }) %>

<section class="page-intro compact-intro">
  <span class="eyebrow">Admin inbox</span>
  <h1>Contact messages</h1>
  <p>Messages from the public contact form are listed here for quick review.</p>
</section>

<section class="dashboard-actions">
  <a class="button ghost" href="/admin/products">Back to products</a>
</section>

<section class="table-card">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>E-mail</th>
        <th>Message</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% contacts.forEach((contact) => { %>
        <tr>
          <td><%= contact.id %></td>
          <td><strong><%= contact.name %></strong></td>
          <td><%= contact.email %></td>
          <td><%= contact.message %></td>
          <td><%= contact.created_at %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/footer') %>
