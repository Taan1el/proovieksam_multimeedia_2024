<%- include('partials/header', { title: 'E-pood', user }) %>

<section style="padding:16px 0">
  <h2>E-pood</h2>
  <p class="muted">Kategooriafilter, max hind ja sorteerimine (Multimeedia eksami nõue).</p>

  <form method="GET" action="/shop" class="card" style="padding:14px;margin:12px 0;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end">
    <div class="field" style="margin:0">
      <label>Kategooria</label>
      <select name="category">
        <% const c = String(query?.category || 'all'); %>
        <option value="all" <%= c === 'all' ? 'selected' : '' %>>Kõik</option>
        <option value="tshirt" <%= c === 'tshirt' ? 'selected' : '' %>>T-särk</option>
        <option value="mouse" <%= c === 'mouse' ? 'selected' : '' %>>Hiir</option>
        <option value="hat" <%= c === 'hat' ? 'selected' : '' %>>Müts</option>
        <option value="mug" <%= c === 'mug' ? 'selected' : '' %>>Kruus</option>
      </select>
    </div>
    <div class="field" style="margin:0">
      <label>Sorteeri</label>
      <% const s = String(query?.sort || 'name'); %>
      <select name="sort">
        <option value="name" <%= s === 'name' ? 'selected' : '' %>>Nimi</option>
        <option value="price-asc" <%= s === 'price-asc' ? 'selected' : '' %>>Hind ↑</option>
        <option value="price-desc" <%= s === 'price-desc' ? 'selected' : '' %>>Hind ↓</option>
      </select>
    </div>
    <div class="field" style="margin:0">
      <label>Max hind (€)</label>
      <input name="maxPrice" type="number" step="1" min="1" value="<%= query?.maxPrice || 9999 %>" />
    </div>
    <button class="btn primary" type="submit">Rakenda</button>
    <a class="btn" href="/shop">Lähtesta</a>
  </form>
</section>

<section class="grid cols-3">
  <% products.forEach(p => { %>
    <a class="card product" href="/product/<%= p.id %>" style="text-decoration:none;color:inherit">
      <div class="thumb" style="overflow:hidden">
        <% if (p.thumb) { %>
          <img src="<%= p.thumb %>" alt="" style="width:100%;height:100%;object-fit:cover" />
        <% } %>
      </div>
      <b><%= p.name %></b>
      <div class="row">
        <span class="muted"><%= p.category %></span>
        <span><b>€<%= p.price %></b></span>
      </div>
    </a>
  <% }) %>
</section>

<%- include('partials/footer') %>
