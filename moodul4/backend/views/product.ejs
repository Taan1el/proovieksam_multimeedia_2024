<%- include('partials/header', { title: product.name, user }) %>

<section class="page-intro compact-intro">
  <span class="eyebrow">Product detail</span>
  <h1><%= product.name %></h1>
  <p>Detailed product page with image gallery, available sizes, colors and full merch info.</p>
</section>

<section class="split-layout">
  <div class="gallery-card">
    <div class="gallery-main">
      <% if (images.length) { %>
        <% images.forEach((image, index) => { %>
          <img class="gallery-slide" data-slide="<%= index %>" src="<%= image.path %>" alt="<%= product.name %>" style="display:<%= index === 0 ? 'block' : 'none' %>">
        <% }) %>
      <% } else { %>
        <div class="empty-state">No images uploaded yet.</div>
      <% } %>
    </div>

    <% if (images.length > 1) { %>
      <div class="gallery-actions">
        <button class="button ghost" type="button" data-car-prev>&#9664;</button>
        <button class="button ghost" type="button" data-car-next>&#9654;</button>
      </div>
      <div class="gallery-thumbs">
        <% images.forEach((image, index) => { %>
          <button type="button" data-thumb="<%= index %>">
            <img src="<%= image.path %>" alt="<%= product.name %> thumbnail">
          </button>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="detail-card">
    <span class="eyebrow">Catalog entry</span>
    <h2><%= product.name %></h2>
    <p><%= product.description %></p>
    <div class="detail-price">EUR <%= product.price %></div>
    <div class="detail-list">
      <div>
        <strong>Category</strong>
        <span><%= product.category %></span>
      </div>
      <div>
        <strong>Sizes</strong>
        <span><%= product.sizes || '-' %></span>
      </div>
      <div>
        <strong>Colors</strong>
        <span><%= product.colors || '-' %></span>
      </div>
      <div>
        <strong>Images</strong>
        <span><%= images.length %></span>
      </div>
    </div>
    <div class="hero-actions">
      <a class="button primary" href="/shop">Back to store</a>
      <% if (user) { %>
        <a class="button ghost" href="/admin/products/<%= product.id %>/edit">Edit in admin</a>
      <% } %>
    </div>
  </div>
</section>

<script>
  (function () {
    var slides = document.querySelectorAll('.gallery-slide');
    if (!slides.length) return;
    var idx = 0;
    function show(i) {
      idx = (i + slides.length) % slides.length;
      slides.forEach(function (slide, slideIndex) {
        slide.style.display = slideIndex === idx ? 'block' : 'none';
      });
    }
    document.querySelector('[data-car-prev]')?.addEventListener('click', function () { show(idx - 1); });
    document.querySelector('[data-car-next]')?.addEventListener('click', function () { show(idx + 1); });
    document.querySelectorAll('[data-thumb]').forEach(function (button) {
      button.addEventListener('click', function () {
        show(Number(button.getAttribute('data-thumb')));
      });
    });
  })();
</script>

<%- include('partials/footer') %>
