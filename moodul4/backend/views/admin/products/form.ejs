<%- include('../../partials/header', { title: product?.id ? 'NEXUS - Edit product' : 'NEXUS - Add product', user }) %>

<section class="page-intro compact-intro">
  <span class="eyebrow">Admin form</span>
  <h1><%= product?.id ? 'Edit product' : 'Add product' %></h1>
  <p>Manage name, category, description, price and uploaded product images.</p>
</section>

<section class="form-card">
  <form method="POST" enctype="multipart/form-data" action="<%= product?.id ? ('/admin/products/' + product.id) : '/admin/products' %>">
    <div class="split-layout">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" value="<%= product?.name || '' %>">
        <% if (errors?.name) { %><div class="error"><%= errors.name %></div><% } %>
      </div>

      <div class="field">
        <label for="category">Category</label>
        <input id="category" name="category" value="<%= product?.category || '' %>" placeholder="tshirt / hat / mouse / mug">
        <% if (errors?.category) { %><div class="error"><%= errors.category %></div><% } %>
      </div>
    </div>

    <div class="field">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4"><%= product?.description || '' %></textarea>
      <% if (errors?.description) { %><div class="error"><%= errors.description %></div><% } %>
    </div>

    <div class="split-layout">
      <div class="field">
        <label for="price">Price</label>
        <input id="price" name="price" type="number" step="0.01" value="<%= product?.price || '' %>">
        <% if (errors?.price) { %><div class="error"><%= errors.price %></div><% } %>
      </div>

      <div class="field">
        <label for="images">Images</label>
        <input id="images" name="images" type="file" multiple accept="image/*">
      </div>
    </div>

    <div class="split-layout">
      <div class="field">
        <label for="sizes">Sizes</label>
        <input id="sizes" name="sizes" value="<%= product?.sizes || '' %>" placeholder="S, M, L, XL">
      </div>

      <div class="field">
        <label for="colors">Colors</label>
        <input id="colors" name="colors" value="<%= product?.colors || '' %>" placeholder="Black, Green, White">
      </div>
    </div>

    <% if (images?.length) { %>
      <div class="existing-images">
        <% images.forEach((image) => { %>
          <div class="existing-image">
            <img src="<%= image.path %>" alt="Existing product image">
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="hero-actions">
      <button class="button primary" type="submit">Save</button>
      <a class="button ghost" href="/admin/products">Back</a>
    </div>
  </form>
</section>

<%- include('../../partials/footer') %>
