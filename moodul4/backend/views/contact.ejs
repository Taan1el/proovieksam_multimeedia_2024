<%- include('partials/header', { title: 'Kontakt', user }) %>

<section style="padding:16px 0" class="grid cols-2">
  <div class="card" style="padding:14px">
    <h2>Kontaktivorm</h2>
    <p class="muted">Sõnumid salvestatakse faili <code>db.json</code> (<code>contacts</code> massiiv), mitte SQLite.</p>

    <% if (ok) { %>
      <div class="card" style="padding:12px;border-color:rgba(34,197,94,.5)">Sõnum on saadetud.</div>
    <% } %>

    <form method="POST" action="/contact">
      <div class="field">
        <label>Nimi</label>
        <input name="name" autocomplete="name" />
        <% if (errors?.name) { %><div class="error"><%= errors.name %></div><% } %>
      </div>
      <div class="field">
        <label>E-post</label>
        <input name="email" type="email" autocomplete="email" />
        <% if (errors?.email) { %><div class="error"><%= errors.email %></div><% } %>
      </div>
      <div class="field">
        <label>Sõnum</label>
        <textarea name="message" rows="5"></textarea>
        <% if (errors?.message) { %><div class="error"><%= errors.message %></div><% } %>
      </div>
      <button class="btn green" type="submit">Saada</button>
    </form>
  </div>
  <div class="card" style="padding:14px">
    <h2>Kontaktandmed</h2>
    <div class="muted">hello@nexus.gg</div>
    <div class="muted">+372 5555 5555</div>
  </div>
</section>

<%- include('partials/footer') %>
