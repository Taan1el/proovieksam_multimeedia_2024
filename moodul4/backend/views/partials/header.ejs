<!doctype html>
<html lang="et">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title || "NEXUS" %></title>
    <link rel="icon" type="image/svg+xml" href="/nexus_logo.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Teko:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href="/">
          <img src="/nexus_logo.svg" alt="NEXUS" width="150" height="34">
        </a>

        <nav class="header-nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/shop">Store</a>
          <a href="/contact">Contact</a>
          <% if (user) { %>
            <a href="/admin/products">Admin</a>
            <form method="POST" action="/admin/logout">
              <button type="submit" class="nav-button">Logout</button>
            </form>
          <% } else { %>
            <a href="/admin/login">Admin</a>
          <% } %>
        </nav>
      </div>
    </header>
    <main class="page-shell shell">
