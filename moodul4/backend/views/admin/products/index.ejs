<%- include('../../partials/header', { title: 'NEXUS - Admin products', user }) %>

<section class="page-intro compact-intro">
  <span class="eyebrow">Admin</span>
  <h1>Product dashboard</h1>
  <p>Add, edit and remove products while keeping the public store in sync.</p>
</section>

<section class="dashboard-actions">
  <a class="button primary" href="/admin/products/create">Add product</a>
  <a class="button ghost" href="/admin/contacts">Open inbox</a>
</section>

<section class="table-card">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Category</th>
        <th>Price</th>
        <th>Images</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach((product) => { %>
        <tr>
          <td><%= product.id %></td>
          <td><strong><%= product.name %></strong></td>
          <td><%= product.category %></td>
          <td>EUR <%= product.price %></td>
          <td><%= product.images.length %></td>
          <td class="table-actions">
            <a class="button ghost small" href="/admin/products/<%= product.id %>/edit">Edit</a>
            <form method="POST" action="/admin/products/<%= product.id %>/delete">
              <button class="button ghost small" type="submit" onclick="return confirm('Delete product?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../../partials/footer') %>
